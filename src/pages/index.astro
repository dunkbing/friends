---
import Layout from "../layouts/Layout.astro";
import allData from "../data/allData.json";
---

<Layout>
  <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6">
    <h2 class="text-sm font-medium text-fg-muted mb-6 tracking-wide uppercase">All Seasons</h2>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
      {allData.map((season) => (
        <a href={`/season/${season.season}`} class="group">
          <div class="overflow-hidden rounded-xl border border-border bg-surface-alt transition-all duration-200 group-hover:-translate-y-1 group-hover:border-accent/40 group-hover:shadow-lg group-hover:shadow-accent/5">
            <div class="aspect-[3/4] overflow-hidden">
              <img
                src={`/thumbnails/Seasons/Season-${season.season}.jpg`}
                alt={`Season ${season.season}`}
                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <div class="p-3">
              <h3 class="font-semibold text-sm group-hover:text-accent transition-colors">
                Season {season.season}
              </h3>
              <p class="text-xs text-fg-muted mt-0.5">{season.release}</p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
