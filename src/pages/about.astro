---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About - Friends TV Series" description="About the Friends TV Series viewer.">
  <div class="mx-auto max-w-2xl px-4 py-12 sm:px-6">
    <h1 class="text-2xl font-semibold mb-8">About</h1>

    <div class="space-y-6 text-sm leading-relaxed text-fg-muted">
      <p>
        A minimal, ad-free viewer for the Friends TV series. Browse all 10
        seasons and 236 episodes in a clean interface.
      </p>

      <div class="border-t border-border pt-6">
        <h2 class="text-xs font-medium text-fg uppercase tracking-wide mb-2">Content Sources</h2>
        <p>
          Video links are sourced from publicly available third-party APIs.
          This project serves as an interface to access this content and does
          not host, store, or distribute any copyrighted material.
        </p>
      </div>

      <div class="border-t border-border pt-6">
        <h2 class="text-xs font-medium text-fg uppercase tracking-wide mb-2">Disclaimer</h2>
        <p>
          This is a non-commercial, personal project. All "Friends" content,
          characters, and related intellectual property belong to Warner Bros.
          Entertainment Inc. Not affiliated with or endorsed by Warner Bros. or NBC.
        </p>
      </div>
    </div>
  </div>
</Layout>
